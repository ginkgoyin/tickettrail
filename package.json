{
  "name": "tickettrail",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:windows": "tauri build --bundles nsis",
    "release:windows": "npm.cmd run build && npm.cmd run tauri:build:windows",
    "data:generate:airports": "node scripts/generate-airports-data.mjs",
    "data:generate:place-catalog": "node scripts/generate-place-catalog-data.mjs --download",
    "data:generate:transport-place": "node scripts/generate-transport-place-data.mjs",
    "data:generate:rail-stations": "node scripts/generate-rail-stations-data.mjs",
    "generate:rail-stations": "node scripts/generate-rail-stations-data.mjs --download",
    "version:sync": "node scripts/sync-version.mjs",
    "version:check": "node scripts/check-release-version.mjs",
    "data:validate:rail-station-place": "node scripts/validate-rail-station-place-coverage.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "maplibre-gl": "^5.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^4.1.7"
  }
}
